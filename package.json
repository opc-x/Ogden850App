{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "preview": "vite preview",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "env:sync": "tsx scripts/sync-integration-env.ts",
    "import:vocab": "tsx scripts/import-vocab.ts",
    "fix:ipa": "tsx scripts/fix-ipa-unicode.ts",
    "sync:dialogues": "tsx scripts/sync-scene-dialogues.ts",
    "tts:generate": "tsx scripts/generate-word-tts.ts",
    "audio:guides": "tsx scripts/generate-guide-audio.ts",
    "audio:audit-guides": "tsx scripts/audit-guide-audio.ts",
    "audio:sync": "tsx scripts/sync-prod-audio.ts",
    "audit:dialogues": "tsx scripts/audit-dialogue-quality.ts",
    "audit:closing": "tsx scripts/audit-closing-phrases.ts",
    "audit:duplicates": "tsx scripts/audit-duplicate-lines.ts",
    "audit:coherence": "tsx scripts/audit-narrative-coherence-llm.ts",
    "coherence:loop": "tsx scripts/coherence-fix-loop.ts",
    "coherence:fix-scene": "tsx scripts/coherence-fix-scene.ts",
