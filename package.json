    "audit:guides": "tsx scripts/audit-guide-quality.ts",
    "audit:ipa": "node --experimental-strip-types scripts/audit-ipa-authority.ts",
    "audit:word-visuals": "tsx scripts/audit-word-visuals.ts",
    "generate:word-svgs": "tsx scripts/generate-word-svgs.ts",
    "sync:word-png-manifest": "tsx scripts/sync-word-png-manifest.ts",
    "audit:word-png": "tsx scripts/audit-word-png.ts",
    "audit:word-png-heuristic": "tsx scripts/audit-word-png-heuristic.ts",
    "generate:word-pngs": "tsx scripts/generate-word-pngs.ts",
    "pipeline:word-png": "tsx scripts/word-png-pipeline.ts",
    "build:word-png-prompts": "tsx scripts/build-word-png-prompts.ts",
    "normalize:word-pngs": "bash scripts/normalize-word-pngs.sh",
    "queue:word-png": "tsx scripts/list-word-png-queue.ts",
    "repair:dialogues": "tsx scripts/repair-dialogues-llm.ts",
    "regenerate:dialogues": "tsx scripts/regenerate-all-dialogues.ts",
    "fix:closing": "tsx scripts/fix-closing-dialogues.ts",
    "closing:loop": "tsx scripts/closing-loop.ts",
    "repair:guides": "tsx scripts/repair-guides-llm.ts",
    "db:migrate": "tsx scripts/apply-migration.ts",
    "generate:covers": "tsx scripts/generate-scene-covers.ts",
    "generate:illustrations": "tsx scripts/generate-scene-illustrations.ts",
    "test": "vitest",
    "dev:backend": "vercel dev",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-virtual": "^3.14.3",
    "@vitejs/plugin-react": "^5.0.4",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "openai": "^6.42.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.17.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vercel/node": "^5.8.17",
    "dotenv": "^17.4.2",
    "esbuild": "^0.25.0",
    "jsdom": "^29.1.1",
    "pg": "^8.21.0",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.22.4",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
