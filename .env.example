# Vercel Supabase integration (Ogden850App_* names) — `vercel env pull` may download empty values locally.
# Run: npm run env:sync  (writes URL + anon key from linked integration project)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
Ogden850App_SUPABASE_URL=
Ogden850App_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# 从 Supabase Dashboard → Settings → API → service_role 复制；pilot/sync 写入库需要


# Gemini — server-side only (api/*.ts, server.ts, scripts). Never commit real keys.
# Local: put your key in .env.local (gitignored). Vercel: Project Settings → Environment Variables.
GEMINI_API_KEY=

# DeepSeek — 陪练评判主路 + 对话生成 (model: deepseek-v4-flash)
DEEPSEEK_API_KEY=

# OpenRouter — 陪练评判兜底（DeepSeek/Gemini 不可用时）
OPENROUTER_API_KEY=

# NVIDIA — Parakeet 0.6B 语音转写（api/transcribe.ts，按住说话）
NVIDIA_API_KEY=

# ── Supabase Auth（Dashboard 配置，见下）──
# 1. Authentication → Providers → 主页面关掉 Confirm email（不在 Email 侧栏里）
# 2. Authentication → Providers → Google → 填入 Google OAuth Client ID/Secret
# 3. Authentication → URL Configuration → Site URL / Redirect URLs:
#    http://localhost:5173/  与生产域名（如 https://your-app.vercel.app/）
# 4. Authentication → SMTP → 配置自定义 SMTP（生产必做，内置邮件约 2 封/小时）
#    https://supabase.com/dashboard/project/runrqlsdzdjjdgjjrchk/auth/smtp
#    Enable custom SMTP → ON，对照下表（Password 用 RESEND_API_KEY）：
#      Host: smtp.resend.com | Port: 465 | Username: resend
#      Sender email: noreply@你的已验证域名.com | Sender name: Ogden 850
#    Resend 域名验证（未验证域无法发信）: https://resend.com/domains
#    保存后去 Rate Limits 把邮件额度调高：
#    https://supabase.com/dashboard/project/runrqlsdzdjjdgjjrchk/auth/rate-limits
# 5. Authentication → Providers → 主页面关掉 Confirm email（访客 signUp 不发信）
#    https://supabase.com/dashboard/project/runrqlsdzdjjdgjjrchk/auth/providers
# 本地开发可设 VITE_MOCK_GUEST_AUTH=true 绕过访客 signUp 限流
VITE_MOCK_GUEST_AUTH=

# Resend — 仅用于 Supabase Dashboard → Auth → SMTP Settings 的 Password 字段
# 不要在 Ogden850 前端/业务代码里 import resend；Auth 邮件由 Supabase 经 SMTP 代发
RESEND_API_KEY=

# Optional — only if you intentionally call from browser (not recommended; exposes key)
VITE_GEMINI_API_KEY=
VITE_DEEPSEEK_API_KEY=
VITE_OPENAI_API_KEY=
